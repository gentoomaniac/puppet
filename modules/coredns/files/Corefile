gentoomaniac.net srv.gentoomaniac.net sto.gentoomaniac.net 1.1.10.in-addr.arpa {
    auto {
        directory /data/dnsdata/zones/ (.*)\.db
        reload 60s
    }
    # If the record isn't in the .db files, pass it to the block below
    fallthrough
}

.:53 {
    # Cloudflare Family DNS (Malware + Adult Content Filtering)
    forward . 1.0.0.3:53 1.1.1.3:53
    cache 60
    log
    errors
    prometheus 0.0.0.0:9153
}
